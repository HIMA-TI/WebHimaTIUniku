# =========================
# FRONTEND (Vite)
# =========================
# Base URL untuk backend API.
# Rekomendasi:
# - Dev (pakai proxy Vite): /api
# - Tanpa proxy / beda domain: http(s)://host:port/api
VITE_API_BASE_URL=/api

# =========================
# DEV ONLY (Vite Proxy)
# =========================
# Kalau di atas pakai VITE_API_BASE_URL=/api, Vite dev server akan nge-proxy request
# /api/* ke backend di bawah ini (menghindari CORS saat development).
DEV_API_PROXY_TARGET=http://localhost:3000
